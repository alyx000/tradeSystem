<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Sleep policy: 尾盘扫描错过可接受（非交易触发，休眠期间不触发，需盘中 mac 唤醒） -->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.alyx.tradesystem.tail-scan</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/alyx/tradeSystem/deploy/launchd/tail-scan-runner.sh</string>
    </array>
    <key>StartCalendarInterval</key>
    <array>
        <dict>
            <key>Weekday</key>
            <integer>1</integer>
            <key>Hour</key>
            <integer>14</integer>
            <key>Minute</key>
            <integer>40</integer>
        </dict>
        <dict>
            <key>Weekday</key>
            <integer>2</integer>
            <key>Hour</key>
            <integer>14</integer>
            <key>Minute</key>
            <integer>40</integer>
        </dict>
        <dict>
            <key>Weekday</key>
            <integer>3</integer>
            <key>Hour</key>
            <integer>14</integer>
            <key>Minute</key>
            <integer>40</integer>
        </dict>
        <dict>
            <key>Weekday</key>
            <integer>4</integer>
            <key>Hour</key>
            <integer>14</integer>
            <key>Minute</key>
            <integer>40</integer>
        </dict>
        <dict>
            <key>Weekday</key>
            <integer>5</integer>
            <key>Hour</key>
            <integer>14</integer>
            <key>Minute</key>
            <integer>40</integer>
        </dict>
    </array>
    <key>StandardOutPath</key>
    <string>/tmp/tradesystem-tail-scan.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/tradesystem-tail-scan.log</string>
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
