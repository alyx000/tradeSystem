# 复制此文件为 .env 并填入真实值
# .env 文件已在 .gitignore 中，不会被提交

# ============================================
# 数据源配置
# ============================================

# Tushare (主力数据源，需 10000 积分)
TUSHARE_TOKEN=your_tushare_token_here
# 可选：Pro API 地址。代码里默认写死为 http://tushare.xyz；探测脚本 diagnose_tushare.py 可用本变量覆盖（如 https://api.tushare.pro）
# TUSHARE_HTTP_URL=https://api.tushare.pro


# ============================================
# 推送渠道配置
# ============================================

# Discord Webhook
# 获取方式：Discord 频道设置 → 集成 → Webhooks → 新建 Webhook
DISCORD_WEBHOOK_PRE=https://discord.com/api/webhooks/xxx
DISCORD_WEBHOOK_POST=https://discord.com/api/webhooks/xxx
DISCORD_WEBHOOK_ALERT=https://discord.com/api/webhooks/xxx

# QQ Bot
# 通过 OpenClaw message 工具推送，无需配置 API
# 在 config.yaml 中配置推送目标：
#   qq.channels.pre_market: "user:openid_xxx" 或 "group:group_xxx"
#   qq.channels.post_market: "group:group_xxx"
#   qq.channels.alerts: "user:openid_xxx"

# 企业微信机器人
# 获取方式：企业微信 → 工作台 → 机器人 → 添加 → 复制 Webhook 地址
WECHAT_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx


# ============================================
# 其他配置
# ============================================

# 采集（pre/post/evening/watchlist/check 等）默认临时关闭 HTTP 代理，直连 Tushare/AkShare。
# 仅在特殊网络下需要采集也走代理时设为 1。
# TRADESYSTEM_USE_HTTP_PROXY=1

# Obsidian Vault 路径（可选，未设置时使用默认路径）
# OBSIDIAN_DIR=/path/to/your/obsidian-vault


# ============================================
# 研报速读 research-digest（每日 A股研报评级 + 美股 yfinance 评级 → Top3 → 钉钉）
# ============================================

# 钉钉机器人凭据（真实值放 ~/.config/tradeSystem.env，勿入 git；已暴露请立刻 rotate）
# DINGTALK_WEBHOOK_TOKEN=your_access_token_here
# DINGTALK_WEBHOOK_SECRET=your_sign_secret_here

# gemini CLI（美股 LLM 叙事用；缺失/超时自动降级纯结构化，A股默认不叙事）
# GEMINI_BIN=/opt/homebrew/bin/gemini
# GEMINI_MODEL=
# LLM_TIMEOUT_SECONDS=180   # launchd 下 LLM 启动慢，建议 180+

# 美股精选股票池（逗号分隔；不设则用内置默认龙头池）
# RESEARCH_DIGEST_US_TICKERS=NVDA,AMD,AVGO,TSM,MSFT,AAPL,GOOGL,AMZN,META,TSLA,PLTR,LLY,BABA,PDD
