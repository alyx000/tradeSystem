{
  "permissions": {
    "allow": [
      "Bash(make check-scripts)",
      "Bash(open *)"
    ],
    "deny": [
      "mcp__sqlite-readonly__write_query",
      "mcp__sqlite-readonly__create_table"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/guard-sqlite-write.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/cli-change-reminder.sh"
          }
        ]
      }
    ]
  }
}
